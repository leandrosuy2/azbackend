NODE_ENV=development

# ──────────────────────────────────────────────
#  URLs
# ──────────────────────────────────────────────
BACKEND_URL=http://localhost
FRONTEND_URL=http://localhost:3000
PROXY_PORT=4000
PORT=4000

# ──────────────────────────────────────────────
#  Banco de dados (PostgreSQL via docker-compose)
# ──────────────────────────────────────────────
DB_DIALECT=postgres
DB_HOST=localhost
DB_PORT=5432
DB_USER=azchat
DB_PASS=azchat123
DB_NAME=azchat

# Ajuste do pool de conexões (opcional)
# DB_POOL_MAX=10
# DB_POOL_MIN=2
# DB_POOL_ACQUIRE=30000
# DB_POOL_IDLE=600000

# ──────────────────────────────────────────────
#  Redis (via docker-compose)
# ──────────────────────────────────────────────
REDIS_URI=redis://:azchat123@127.0.0.1:6379
REDIS_OPT_LIMITER_MAX=1
REGIS_OPT_LIMITER_DURATION=3000
# REDIS_URI_ACK=   # segundo Redis para ACKs (opcional)

# ──────────────────────────────────────────────
#  JWT
# ──────────────────────────────────────────────
JWT_SECRET=dev_jwt_secret_troque_em_producao
JWT_REFRESH_SECRET=dev_jwt_refresh_secret_troque_em_producao

# ──────────────────────────────────────────────
#  Limites da aplicação
# ──────────────────────────────────────────────
USER_LIMIT=999
CONNECTIONS_LIMIT=999
CLOSED_SEND_BY_ME=true
TIMEOUT_TO_IMPORT_MESSAGE=1000
MASTER_KEY=senha_master_dev

# ──────────────────────────────────────────────
#  Tokens de verificação
# ──────────────────────────────────────────────
VERIFY_TOKEN=whaticket
COMPANY_TOKEN=whaticket

# Token público usado pelo frontend para buscar logo/cores/nome da empresa
# Deve bater com o valor hardcoded em frontend/src/hooks/useSettings/index.js ("wtV")
ENV_TOKEN=wtV

# ──────────────────────────────────────────────
#  Bull Board (fila – painel /queues)
# ──────────────────────────────────────────────
BULL_USER=admin
BULL_PASS=admin123

# ──────────────────────────────────────────────
#  E-mail (SMTP)
# ──────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=seuemail@gmail.com
SMTP_PASS=suasenhaapp
SMTP_FROM="AzChat Dev <seuemail@gmail.com>"

# ──────────────────────────────────────────────
#  Pagamentos (opcional em dev)
# ──────────────────────────────────────────────
MP_ACCESS_TOKEN=

# ──────────────────────────────────────────────
#  Facebook / WhatsApp Business API (opcional)
# ──────────────────────────────────────────────
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=

# ──────────────────────────────────────────────
#  Gerencianet / PIX (opcional)
# ──────────────────────────────────────────────
GERENCIANET_SANDBOX=true
GERENCIANET_CLIENT_ID=
GERENCIANET_CLIENT_SECRET=
GERENCIANET_PIX_CERT=

# ──────────────────────────────────────────────
#  Integrações externas (opcional)
# ──────────────────────────────────────────────
SENTRY_DSN=
PERFEX_URL=
PERFEX_MODULE=

# Modo demonstração (ON / OFF)
DEMO=OFF
APP_TRIALEXPIRATION=3

# Socket.IO Admin UI (true / false)
SOCKET_ADMIN=false
